{
  "manifest_version": 3,
  "name": "HTML Edit",
  "version": "1.2",
  "description": "一键编辑网页文字 + 拖拽替换图片",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "HTML Edit — 点击开启/关闭"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
